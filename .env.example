# AdminLaw Coach — environment variables (placeholders only; real secrets never committed, §2.4)

# Anthropic (server-side only). Use a re_test_… style restricted key in dev where possible.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Model selection (optional — sensible Tier-B-cost defaults are baked in)
#   default generation model: best quality/cost balance for grounded legal answers
ADMINLAW_DEFAULT_MODEL=claude-sonnet-4-6
#   small model: cheap structural-repair pass
ADMINLAW_SMALL_MODEL=claude-haiku-4-5

# Upstash Redis (cost meter + rate limit, fail-closed §6.4).
# Accept either the Marketplace-injected KV_* names OR the legacy UPSTASH_* names (§15).
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Cost guard (§6.9). SESSION_CAP_USD is the operator-funded per-session spend cap (USD).
SESSION_CAP_USD=0.5
GLOBAL_DAILY_BUDGET_USD=50

# Public base URL (SEO canonical/sitemap/robots — single source, §8)
NEXT_PUBLIC_SITE_URL=https://adminlaw-coach.vercel.app

# GA4 (PII-safe, §8.2). Loader no-ops when unset, so dev never pollutes prod analytics.
NEXT_PUBLIC_GA_ID=

# Contact form (/contact, §16.3) — required for it to actually send.
# Until these are set the form degrades gracefully (returns "not set up yet"); no email is sent.
# In dev use a re_test_… key (sandbox, §16.5). In prod, the FROM_EMAIL domain must be Verified in Resend (§16.1).
RESEND_API_KEY=re_test_REPLACE_ME
ADMIN_NOTIFY_EMAIL=raymond.zheng@gmail.com
FROM_EMAIL=noreply@adminlaw-coach.app
